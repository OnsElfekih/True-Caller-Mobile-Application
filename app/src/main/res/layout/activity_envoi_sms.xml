<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/background"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/tvEnvoiSms_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:text="Envoie SMS"
        android:textAlignment="center"
        android:textColor="#2196F3"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvNomContact_sms"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="30dp"
        android:text="Ecrire un message à "
        android:textAlignment="center"
        android:textColor="#757575"
        android:textSize="16sp"
        android:textStyle="italic" />

    <EditText
        android:id="@+id/edMessage_sms"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:hint="Saisir votre message ici..."
        android:gravity="top"
        android:padding="10dp"
        android:background="@android:color/white"
        android:elevation="2dp"
        android:inputType="textMultiLine" />

    <Button
        android:id="@+id/btnEnvoi_sms"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:backgroundTint="#2196F3"
        android:text="Envoyer"
        android:textColor="@android:color/white" />

    <Button
        android:id="@+id/btnQuitter_sms"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:backgroundTint="#9E9E9E"
        android:text="Quitter"
        android:textColor="@android:color/white" />

</LinearLayout>
